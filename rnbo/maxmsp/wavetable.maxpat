														"id" : "obj-1",
														"fontsize" : 12.0,
														"numinlets" : 1,
														"code" : "samps = mstosamps(lag);\r\nf2rps = 2*pi/samplerate;\n_xlfo = slide(xlfo, samps, samps);\r\n_ylfo = slide(ylfo, samps, samps);\r\nreset = in1;\r\n\r\n// convert frequencies to radians-per-sample\r\n// generate sinewave\r\ncol = sin(plusequals(_xlfo*f2rps, reset));\r\nrow = sin(plusequals(_ylfo*f2rps, reset));\r\nout1 = scale(col, -1., 1., 0., 1., 1);\r\nout2 = scale(row, -1., 1., 0., 1., 1);"
													}

												}
